# Keystore configuration for release APK signing
# IMPORTANT: Generate your own keystore and fill in these values
# DO NOT commit the actual key.properties file to version control

# Path to your keystore file (relative to android/ directory)
# Example: storeFile=keystore/release_keystore.jks
storeFile=

# Password for the keystore file
storePassword=

# Alias of the key within the keystore
keyAlias=

# Password for the specific key
keyPassword=
